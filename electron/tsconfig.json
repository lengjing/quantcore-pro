{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es6",
        "outDir": "../dist-electron",
        "rootDir": ".",
        "sourceMap": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "**/*"
    ]
}