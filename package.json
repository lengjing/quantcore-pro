{
  "name": "quantcore-pro",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && npx tsc -p electron/tsconfig.json && electron .\"",
    "electron:build": "npx tsc -p electron/tsconfig.json && vite build && electron-builder",
    "compile:python": "pyinstaller --onefile --distpath python_dist python/main.py"
  },
  "build": {
    "appId": "com.quantcore.pro",
    "productName": "QuantCore Pro",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "python_dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "python_dist",
        "to": "python_dist"
      }
    ]
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "@monaco-editor/react": "4.6.0",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.0",
    "recharts": "^3.5.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.3"
  }
}
