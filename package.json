{
  "name": "quantcore-pro",
  "private": true,
  "version": "1.0.1",
  "description": "QuantCore Pro — quantitative trading terminal",
  "author": "QuantCore",
  "main": "dist-electron/main.js",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"cross-env BROWSER=none pnpm run dev\" \"pnpm exec tsc -p electron/tsconfig.json && electron .\"",
    "electron:build": "pnpm exec tsc -p electron/tsconfig.json && vite build && electron-builder"
  },
  "build": {
    "appId": "com.quantcore.pro",
    "productName": "QuantCore Pro",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "generic",
      "url": "https://pub-8a0bf3b6674f429abf20220dbbd6acc7.r2.dev"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@google/genai": "^2.5.0",
    "@monaco-editor/react": "^4.7.0",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "i18next": "^26.2.0",
    "lightweight-charts": "5.2.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.8",
    "react-is": "^19.2.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.13"
  }
}
